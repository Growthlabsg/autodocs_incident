# ===================================
# AutoDocs+AutoIncident Configuration
# ===================================

# Environment
NODE_ENV=development
PORT=3001

# ===================================
# Database Configuration
# ===================================
DATABASE_URL=postgresql://postgres:password@localhost:5432/autodocs_incident
DB_HOST=localhost
DB_PORT=5432
DB_NAME=autodocs_incident
DB_USER=postgres
DB_PASSWORD=your_secure_password

# Database Pool
DB_POOL_MIN=2
DB_POOL_MAX=10

# ===================================
# Authentication & Security
# ===================================
# CRITICAL: Change these in production!
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRY=24h
REFRESH_TOKEN_SECRET=your-refresh-token-secret-change-this
REFRESH_TOKEN_EXPIRY=7d

# Encryption
ENCRYPTION_KEY=your-32-character-encryption-key-here

# Session
SESSION_SECRET=your-session-secret-change-this

# ===================================
# Frontend Configuration
# ===================================
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ===================================
# OpenAI Configuration (for AI features)
# ===================================
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4
OPENAI_MAX_TOKENS=2000

# ===================================
# Slack Integration
# ===================================
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_SIGNING_SECRET=your-slack-signing-secret
SLACK_APP_TOKEN=xapp-your-slack-app-token
SLACK_CLIENT_ID=your-slack-client-id
SLACK_CLIENT_SECRET=your-slack-client-secret

# ===================================
# Email Configuration (SMTP)
# ===================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password
EMAIL_FROM=noreply@autodocs.com

# ===================================
# SMS Configuration (Twilio)
# ===================================
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# ===================================
# Redis Configuration (optional, for caching)
# ===================================
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ===================================
# Alert Source Integrations
# ===================================

# Datadog
DATADOG_API_KEY=your-datadog-api-key
DATADOG_APP_KEY=your-datadog-app-key

# New Relic
NEW_RELIC_API_KEY=your-newrelic-api-key
NEW_RELIC_ACCOUNT_ID=your-account-id

# PagerDuty
PAGERDUTY_API_KEY=your-pagerduty-api-key
PAGERDUTY_INTEGRATION_KEY=your-integration-key

# Grafana
GRAFANA_API_KEY=your-grafana-api-key
GRAFANA_URL=https://your-grafana-instance.com

# Sentry
SENTRY_DSN=your-sentry-dsn
SENTRY_AUTH_TOKEN=your-sentry-auth-token

# ===================================
# Storage Configuration
# ===================================

# AWS S3 (for file uploads)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
S3_BUCKET_NAME=autodocs-incidents

# Or use local storage
UPLOAD_DIR=./uploads

# ===================================
# Monitoring & Observability
# ===================================

# Prometheus
PROMETHEUS_PORT=9090

# Grafana
GRAFANA_ADMIN_PASSWORD=your-grafana-password

# Log Level
LOG_LEVEL=info

# ===================================
# API Configuration
# ===================================

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# ===================================
# Webhook Configuration
# ===================================
WEBHOOK_SECRET=your-webhook-signing-secret-change-this

# ===================================
# On-Call Pay Calculator
# ===================================
ONCALL_HOURLY_RATE=30
ONCALL_WEEKEND_MULTIPLIER=1.5
ONCALL_HOLIDAY_MULTIPLIER=2.0

# ===================================
# SSO Configuration
# ===================================

# SAML
SAML_ENTRY_POINT=https://your-idp.com/saml/login
SAML_ISSUER=autodocs-incident
SAML_CERT=your-saml-certificate

# OAuth2
OAUTH_CLIENT_ID=your-oauth-client-id
OAUTH_CLIENT_SECRET=your-oauth-client-secret
OAUTH_CALLBACK_URL=http://localhost:3001/auth/oauth/callback

# ===================================
# Feature Flags
# ===================================
FEATURE_AI_ENABLED=true
FEATURE_SLACK_ENABLED=true
FEATURE_STATUS_PAGES_ENABLED=true
FEATURE_MOBILE_APP_ENABLED=true
FEATURE_WORKFLOWS_ENABLED=true

# ===================================
# Mobile App Configuration
# ===================================
MOBILE_API_URL=http://localhost:3001
PUSH_NOTIFICATION_KEY=your-push-notification-key

# ===================================
# Development Tools
# ===================================

# Debug
DEBUG=autodocs:*

# Seed Data
SEED_DATABASE=false
SEED_TEST_DATA=false

# ===================================
# Production Settings
# ===================================
# Uncomment and configure for production

# SSL
# SSL_CERT_PATH=/path/to/cert.pem
# SSL_KEY_PATH=/path/to/key.pem

# CDN
# CDN_URL=https://cdn.autodocs.com

# Domain
# DOMAIN=app.autodocs.com

# ===================================
# Notes
# ===================================
# 1. Never commit this file with real values to git
# 2. Add .env to .gitignore
# 3. Use different values for dev/staging/production
# 4. Rotate secrets regularly (every 90 days)
# 5. Use a secrets manager in production (AWS Secrets Manager, Vault, etc.)
