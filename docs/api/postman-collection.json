{
  "info": {
    "name": "AutoDocs+AutoIncident API",
    "description": "Complete API collection for AutoDocs+AutoIncident platform. Import this collection into Postman to test all 100+ endpoints.",
    "version": "1.0.0",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{auth_token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "base_url",
      "value": "https://api.autodocs.com",
      "type": "string"
    },
    {
      "key": "auth_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "incident_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "team_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "user_id",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.collectionVariables.set('auth_token', jsonData.token);",
                  "    pm.collectionVariables.set('user_id', jsonData.user.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@company.com\",\n  \"password\": \"your_password\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Login and get JWT token. The token will be automatically saved to collection variables."
          },
          "response": []
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/refresh",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "refresh"]
            }
          },
          "response": []
        },
        {
          "name": "SSO Login",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/auth/saml/login?org_id=1",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "saml", "login"],
              "query": [
                {
                  "key": "org_id",
                  "value": "1"
                }
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Incidents",
      "item": [
        {
          "name": "List Incidents",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/incidents?severity=SEV1&status=investigating&page=1&per_page=20",
              "host": ["{{base_url}}"],
              "path": ["api", "incidents"],
              "query": [
                {
                  "key": "severity",
                  "value": "SEV1",
                  "description": "Filter by severity: SEV1, SEV2, SEV3, SEV4"
                },
                {
                  "key": "status",
                  "value": "investigating",
                  "description": "Filter by status"
                },
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "per_page",
                  "value": "20"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Create Incident",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.collectionVariables.set('incident_id', jsonData.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Production Database Connection Issues\",\n  \"description\": \"Users experiencing timeout errors when connecting to the database\",\n  \"severity\": \"SEV1\",\n  \"service_id\": 10,\n  \"team_id\": 2,\n  \"assignee_ids\": [5, 8],\n  \"tags\": [\"database\", \"connection\", \"timeout\"]\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/incidents",
              "host": ["{{base_url}}"],
              "path": ["api", "incidents"]
            }
          },
          "response": []
        },
        {
          "name": "Get Incident",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/incidents/{{incident_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "incidents", "{{incident_id}}"]
            }
          },
          "response": []
        },
        {
          "name": "Update Incident",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"monitoring\",\n  \"severity\": \"SEV2\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/incidents/{{incident_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "incidents", "{{incident_id}}"]
            }
          },
          "response": []
        },
        {
          "name": "Post Incident Update",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"message\": \"Root cause identified. Deploying fix now.\",\n  \"notify_channels\": [\"slack\", \"email\"],\n  \"status\": \"identified\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/incidents/{{incident_id}}/updates",
              "host": ["{{base_url}}"],
              "path": ["api", "incidents", "{{incident_id}}", "updates"]
            }
