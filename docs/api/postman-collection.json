            "body": {
              "mode": "raw",
              "raw": "{\n  \"resolution_summary\": \"Fixed by rolling back to previous version\",\n  \"root_cause\": \"Bug in latest deployment\",\n  \"generate_postmortem\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/incidents/{{incident_id}}/resolve",
